---
/**
 * MermaidGantt.astro — Client-side Mermaid renderer for Gantt diagrams.
 * Wrapped in the Prairie Cinematic token system via CSS overrides.
 * Exception to "no client-side JS" rule per Michael's request 2026-07-14.
 */
const { chart } = Astro.props;
---

<div class="mermaid-wrapper" data-mermaid={chart}>
  <div class="mermaid-loading">Loading timeline…</div>
</div>

<script>
  import mermaid from 'mermaid';

  function renderMermaid() {
    const wrappers = document.querySelectorAll<HTMLElement>('.mermaid-wrapper');
    if (wrappers.length === 0) return;

    mermaid.initialize({
      startOnLoad: false,
      theme: 'base',
      themeVariables: {
        fontFamily: 'Inter, system-ui, sans-serif',
        fontSize: '13px',
        // Prairie Cinematic tokens
        primaryColor: '#F5F4F0',
        primaryTextColor: '#1A1A1A',
        primaryBorderColor: '#D4C9B0',
        lineColor: '#6B6B6B',
        secondaryColor: '#F9F8F5',
        tertiaryColor: '#FFFFFF',
        background: '#F9F8F5',
        mainBkg: '#E8F4E8',
        secondBkg: '#FFF7E6',
        // Gantt-specific
        sectionBkgColor: '#F5F4F0',
        altSectionBkgColor: '#F9F8F5',
        sectionBkgColor2: '#F5F4F0',
        taskBkgColor: '#E8F4E8',
        taskTextColor: '#2D6A2D',
        taskTextLightColor: '#6B6B6B',
        taskTextOutsideColor: '#6B6B6B',
        taskTextClickableColor: '#2D6A2D',
        activeTaskBorderColor: '#8B5E00',
        activeTaskBkgColor: '#FFF7E6',
        gridColor: '#D4C9B0',
        doneTaskBkgColor: '#E8F4E8',
        doneTaskBorderColor: '#C8DCC8',
        critBorderColor: '#8B5E00',
        critBkgColor: '#FFF7E6',
        todayLineColor: '#2D2D2D',
        weekendColor: '#F5F4F0',
      },
      gantt: {
        useWidth: 720,
      },
    });

    wrappers.forEach(async (wrapper, i) => {
      const chartDef = wrapper.getAttribute('data-mermaid');
      if (!chartDef) return;
      try {
        const { svg } = await mermaid.render(`gantt-svg-${i}`, chartDef);
        wrapper.innerHTML = svg;
      } catch (err) {
        wrapper.innerHTML = `<div class="mermaid-error">Timeline unavailable</div>`;
        console.error('Mermaid render error:', err);
      }
    });
  }

  // Run after DOM is ready
  if (document.readyState !== 'loading') {
    renderMermaid();
  } else {
    document.addEventListener('DOMContentLoaded', renderMermaid);
  }
</script>

<style>
  .mermaid-wrapper {
    margin: 1.5rem 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mermaid-wrapper :global(svg) {
    max-width: 100%;
    height: auto;
  }

  .mermaid-loading {
    color: var(--color-mid);
    font-size: var(--size-sm);
    font-family: var(--font-body);
    padding: 1rem 0;
  }

  .mermaid-error {
    color: #8B5E00;
    font-size: var(--size-sm);
    font-family: var(--font-body);
    padding: 1rem 0;
  }
</style>
