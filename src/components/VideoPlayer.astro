---
interface Video {
  id: string;
  title: string;
  poster?: string;
}

interface Props {
  videos: Video[];
}

const { videos } = Astro.props;
---

<section class="video-section" aria-label="Video player">
  {videos.map((video, i) => (
    <div class="video-card">
      <div class="video-card__player">
        <div class="video-card__aspect">
          <iframe
            src={`https://iframe.cloudflarestream.com/${video.id}?${video.poster ? `poster=${encodeURIComponent(video.poster)}&` : ''}primaryColor=%232D2D2D&letterboxColor=%231A1A1A`}
            title={video.title}
            loading={i === 0 ? 'eager' : 'lazy'}
            allow="autoplay; encrypted-media; picture-in-picture; fullscreen"
            allowfullscreen
            class="video-card__iframe"
          ></iframe>
        </div>
      </div>
      <div class="video-card__info">
        <h3 class="video-card__title">{video.title}</h3>
        <span class="video-card__badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Stream
        </span>
      </div>
    </div>
  ))}
</section>

<style>
  .video-section {
    margin: 2rem 0 2.5rem;
  }

  .video-card {
    margin-bottom: 2rem;
    background: var(--color-white);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    animation: fadeInUp 0.5s ease-out both;
  }

  .video-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  .video-card:last-child {
    margin-bottom: 0;
  }

  /* 16:9 aspect ratio container */
  .video-card__player {
    background: #1A1A1A;
  }

  .video-card__aspect {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .video-card__iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Info bar below video */
  .video-card__info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    border-top: 1px solid var(--color-rule);
  }

  .video-card__title {
    font-family: var(--font-heading);
    font-size: var(--size-sm);
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
    letter-spacing: 0;
  }

  .video-card__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-mid);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .video-card__badge svg {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .video-card__info {
      padding: 0.75rem 1rem;
    }
  }
</style>
