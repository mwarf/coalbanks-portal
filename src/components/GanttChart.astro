---
/**
 * GanttChart.astro — Static Gantt-style timeline for the production plan.
 * Uses existing Prairie Cinematic design tokens. No client-side JS.
 * Pure HTML/CSS rendered at build time.
 */
const phases = [
  {
    label: 'Pre-Production',
    bars: [
      { text: 'Scouting & Prep', start: 0, span: 3, status: 'done' },
    ],
  },
  {
    label: 'Lifestyle Shoot',
    bars: [
      { text: 'Matt & Steph White', start: 3, span: 1, status: 'done' },
    ],
  },
  {
    label: 'Day 1 — Mon Jul 20',
    bars: [
      { text: 'Lethbridge & Coaldale Interiors', start: 4, span: 1, status: 'active' },
    ],
  },
  {
    label: 'Day 2 — Tue Jul 21',
    bars: [
      { text: 'Team Voices (Construction + Design)', start: 5, span: 1, status: 'active' },
    ],
  },
  {
    label: 'Day 3 — Wed Jul 22',
    bars: [
      { text: 'Crowsnest Pass / Coleman', start: 6, span: 1, status: 'active' },
    ],
  },
  {
    label: 'Day 4 — Thu Jul 23',
    bars: [
      { text: 'Mountain Wrap + Contingency', start: 7, span: 1, status: 'active' },
    ],
  },
  {
    label: 'Doc Profile',
    bars: [
      { text: 'Kim & Trevor Family Profile', start: 11, span: 4, status: 'pending' },
    ],
  },
  {
    label: 'Post-Production',
    bars: [
      { text: 'Social Reels Batch 1', start: 10, span: 2, status: 'pending' },
      { text: 'Anthem First Cut', start: 10, span: 3, status: 'pending' },
      { text: 'Doc First Cuts', start: 11, span: 3, status: 'pending' },
      { text: 'Revisions & Final Delivery', start: 14, span: 3, status: 'pending' },
    ],
  },
];

// Week labels for the header row
const weeks = [
  { label: 'Jul 14', cols: 1 },
  { label: 'Jul 17', cols: 1 },
  { label: 'Jul 20', cols: 1 },
  { label: 'Jul 21', cols: 1 },
  { label: 'Jul 22', cols: 1 },
  { label: 'Jul 23', cols: 1 },
  { label: 'Jul 27', cols: 1 },
  { label: 'Jul 28', cols: 1 },
  { label: 'Jul 29', cols: 1 },
  { label: 'Jul 30', cols: 1 },
  { label: 'Aug 20', cols: 1 },
  { label: 'Aug 24', cols: 1 },
  { label: 'Aug 31', cols: 1 },
  { label: 'Sep 7', cols: 1 },
  { label: 'Sep 21', cols: 1 },
  { label: '', cols: 1 },
];

const totalCols = 16;
---

<div class="gantt">
  <div class="gantt__header">
    <div class="gantt__label-col"></div>
    <div class="gantt__timeline">
      {weeks.map(w => (
        <div class="gantt__week">{w.label}</div>
      ))}
    </div>
  </div>

  {phases.map(phase => (
    <div class="gantt__row">
      <div class="gantt__label-col">
        <span class="gantt__phase-label">{phase.label}</span>
      </div>
      <div class="gantt__timeline">
        <div class="gantt__track">
          {phase.bars.map(bar => (
            <div
              class:list={["gantt__bar", `gantt__bar--${bar.status}`]}
              style={`left: ${(bar.start / totalCols) * 100}%; width: ${(bar.span / totalCols) * 100}%;`}
            >
              <span class="gantt__bar-label">{bar.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  ))}

  <div class="gantt__legend">
    <span class="gantt__legend-item"><span class="gantt__dot gantt__dot--done"></span> Complete</span>
    <span class="gantt__legend-item"><span class="gantt__dot gantt__dot--active"></span> Shoot Week</span>
    <span class="gantt__legend-item"><span class="gantt__dot gantt__dot--pending"></span> Upcoming</span>
  </div>
</div>

<style>
  .gantt {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .gantt__header,
  .gantt__row {
    display: flex;
    align-items: stretch;
  }

  .gantt__header {
    border-bottom: 2px solid var(--color-rule);
    padding-bottom: 0.5rem;
    margin-bottom: 0.25rem;
    min-width: 760px;
  }

  .gantt__label-col {
    flex: 0 0 180px;
    font-family: var(--font-heading);
    font-size: var(--size-sm);
    font-weight: 600;
    color: var(--color-accent);
    padding: 0.5rem 0.75rem 0.5rem 0;
    line-height: 1.3;
  }

  .gantt__timeline {
    flex: 1;
    position: relative;
    min-width: 0;
  }

  .gantt__header .gantt__timeline {
    display: grid;
    grid-template-columns: repeat(16, 1fr);
  }

  .gantt__week {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-mid);
    text-align: left;
    padding-left: 2px;
    white-space: nowrap;
  }

  .gantt__row {
    border-bottom: 1px solid var(--color-rule);
    min-height: 2.5rem;
    min-width: 760px;
  }

  .gantt__row:hover {
    background-color: var(--color-surface);
  }

  .gantt__track {
    position: relative;
    height: 100%;
    min-height: 2.5rem;
    display: flex;
    align-items: center;
  }

  .gantt__bar {
    position: absolute;
    height: 1.75rem;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    padding: 0 0.5rem;
    font-size: 0.72rem;
    font-family: var(--font-body);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: opacity 0.15s ease;
  }

  .gantt__bar:hover {
    opacity: 0.85;
  }

  .gantt__bar-label {
    line-height: 1;
  }

  /* Status colors using existing tokens */
  .gantt__bar--done {
    background-color: #E8F4E8;
    color: #2D6A2D;
    border: 1px solid #C8DCC8;
  }

  .gantt__bar--active {
    background-color: #FFF7E6;
    color: #8B5E00;
    border: 1px solid #E8D9B8;
  }

  .gantt__bar--pending {
    background-color: var(--color-surface);
    color: var(--color-mid);
    border: 1px solid var(--color-rule);
  }

  .gantt__legend {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    padding-top: 0.75rem;
    flex-wrap: wrap;
  }

  .gantt__legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--size-sm);
    color: var(--color-mid);
    font-family: var(--font-body);
  }

  .gantt__dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: var(--radius);
    flex-shrink: 0;
  }

  .gantt__dot--done {
    background-color: #E8F4E8;
    border: 1px solid #C8DCC8;
  }

  .gantt__dot--active {
    background-color: #FFF7E6;
    border: 1px solid #E8D9B8;
  }

  .gantt__dot--pending {
    background-color: var(--color-surface);
    border: 1px solid var(--color-rule);
  }

  @media (max-width: 768px) {
    .gantt__label-col {
      flex: 0 0 110px;
      font-size: 0.7rem;
    }

    .gantt__bar {
      font-size: 0.65rem;
      height: 1.5rem;
      padding: 0 0.35rem;
    }

    .gantt__week {
      font-size: 0.6rem;
    }
  }
</style>
