---
import type { ProjectType } from '../lib/projectTypes';
import { typeLabel } from '../lib/projectTypes';

interface Props {
  type: ProjectType;
}
const { type } = Astro.props;
---
<span class={`type-tag type-tag--${type}`} title={`${typeLabel[type]}`}>
  <svg class="type-tag__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    {type === 'deliverable' && (
      <Fragment>
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
        <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
        <line x1="12" y1="22.08" x2="12" y2="12" />
      </Fragment>
    )}
    {type === 'update' && (
      <Fragment>
        <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
      </Fragment>
    )}
    {type === 'feedback' && (
      <Fragment>
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
      </Fragment>
    )}
    {type === 'brief' && (
      <Fragment>
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
        <polyline points="14 2 14 8 20 8" />
        <line x1="16" y1="13" x2="8" y2="13" />
        <line x1="16" y1="17" x2="8" y2="17" />
        <line x1="10" y1="9" x2="8" y2="9" />
      </Fragment>
    )}
  </svg>
  <span class="type-tag__label">{typeLabel[type]}</span>
</span>
