---
import StatusBadge from './StatusBadge.astro';
import DateStamp from './DateStamp.astro';
import TypeBadge from './TypeBadge.astro';
import type { ProjectType } from '../lib/projectTypes';

interface Props {
  title: string;
  status: 'draft' | 'in-review' | 'delivered' | 'approved';
  url?: string;
  date?: Date;
  type?: ProjectType;
}
const { title, status, url, date, type } = Astro.props;
---
<div class="deliverable-card">
  <div class="deliverable-card__info">
    {type && <TypeBadge type={type} />}
    {url ? (
      <a href={url} class="deliverable-card__title">{title}</a>
    ) : (
      <span class="deliverable-card__title">{title}</span>
    )}
    <StatusBadge status={status} />
  </div>
  {date && (
    <span class="deliverable-card__date">
      <DateStamp date={date} format="short" />
    </span>
  )}
</div>
