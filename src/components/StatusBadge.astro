---
interface Props {
  status: 'draft' | 'in-review' | 'delivered' | 'approved';
}
const { status } = Astro.props;
const labels: Record<string, string> = {
  'draft':     'Draft',
  'in-review': 'In Review',
  'delivered': 'Delivered',
  'approved':  'Approved',
};
---
<span class={`badge badge--${status}`}>{labels[status]}</span>
