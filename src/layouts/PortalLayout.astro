---
import BaseLayout from './BaseLayout.astro';
import StatusBadge from '../components/StatusBadge.astro';
import DateStamp from '../components/DateStamp.astro';
import TypeBadge from '../components/TypeBadge.astro';
import type { ProjectType } from '../lib/projectTypes';

interface Props {
  title:   string;
  client:  string;
  status?: 'draft' | 'in-review' | 'delivered' | 'approved';
  date?:   Date;
  type?:   ProjectType;
}

const { title, client, status, date, type } = Astro.props;

const clientDisplayName = client
  .split('-')
  .map((word: string) => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ');
---
<BaseLayout title={`${title} — Coalbanks Creative`}>
  <div class="portal-wrapper">
    <!-- Header -->
    <header class="portal-header">
      <a href={`/${client}/`} class="portal-header__logo" aria-label="Coalbanks Creative — home">
        <img src="/logo-coalbanks.svg" alt="Coalbanks Creative" />
      </a>
      <a href="mailto:michael@coalbanks.ca" class="portal-header__contact">
        michael@coalbanks.ca
      </a>
    </header>

    <!-- Breadcrumb -->
    <nav class="portal-breadcrumb" aria-label="Breadcrumb">
      <a href={`/${client}/`}>Projects</a>
      <span class="portal-breadcrumb__separator">/</span>
      <span>{clientDisplayName}</span>
    </nav>

    <!-- Main -->
    <main class="portal-main">
      <div class="page-header">
        <h1>{title}</h1>
        {(status || date || type) && (
          <div class="page-header__meta">
            {type && <TypeBadge type={type} />}
            {status && <StatusBadge status={status} />}
            {date && <DateStamp date={date} format="long" />}
          </div>
        )}
      </div>
      <div class="prose">
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer class="portal-footer">
      <span>&copy; Coalbanks Creative Inc.</span>
      <span>{clientDisplayName}</span>
    </footer>
  </div>
</BaseLayout>
