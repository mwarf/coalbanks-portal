---
import { render } from 'astro:content';
import PortalLayout from '../../layouts/PortalLayout.astro';
import DeliverableCard from '../../components/DeliverableCard.astro';
import AssetLink from '../../components/AssetLink.astro';
import Gallery from '../../components/Gallery.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import ProjectSummary from '../../components/ProjectSummary.astro';
import { getPublishedEntries, entrySlug } from '../../lib/portal';

export async function getStaticPaths() {
  const entries = await getPublishedEntries();

  // Group entries by client to get unique client paths
  const clients = [...new Set(entries.map((e) => e.data.client))];

  return clients.map((client) => ({
    params: { client },
  }));
}

const { client } = Astro.params;
const allEntries = (await getPublishedEntries()).filter((e) => e.data.client === client);

// Find the overview/index entry — glob loader gives index.md an id equal to the folder name
const overviewEntry = allEntries.find((e) => e.id === client);

// All other entries, sorted by date descending
const otherEntries = allEntries
  .filter((e) => e.id !== client)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Render the overview content if it exists
let OverviewContent = null;
if (overviewEntry) {
  const rendered = await render(overviewEntry);
  OverviewContent = rendered.Content;
}

const pageTitle = overviewEntry?.data.title ?? `${client} — Project Overview`;
const pageStatus = overviewEntry?.data.status;
const pageDate = overviewEntry?.data.date;
const pageType = overviewEntry?.data.type;
const assetLinks = overviewEntry?.data.asset_links ?? [];
const gallery = overviewEntry?.data.gallery ?? [];
const videos = overviewEntry?.data.videos ?? [];
---
<PortalLayout title={pageTitle} client={client} status={pageStatus} date={pageDate} type={pageType}>
  <ProjectSummary status={pageStatus} entries={otherEntries} fallbackDate={pageDate} />

  {assetLinks.length > 0 && (
    <AssetLink links={assetLinks} />
  )}

  {videos.length > 0 && (
    <VideoPlayer videos={videos} />
  )}

  {OverviewContent && (
    <OverviewContent />
  )}

  {gallery.length > 0 && (
    <Gallery images={gallery} title={pageTitle} />
  )}

  {otherEntries.length > 0 && (
    <section class="notes-list">
      <h2 class="notes-list__heading">Project Timeline</h2>
      {otherEntries.map((entry, i) => {
        return (
          <DeliverableCard
            title={entry.data.title}
            status={entry.data.status}
            url={`/${entry.data.client}/${entrySlug(entry)}`}
            date={entry.data.date}
            type={entry.data.type}
            index={i}
          />
        );
      })}
    </section>
  )}
</PortalLayout>
