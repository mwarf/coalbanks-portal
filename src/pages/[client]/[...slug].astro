---
import { render } from 'astro:content';
import PortalLayout from '../../layouts/PortalLayout.astro';
import AssetLink from '../../components/AssetLink.astro';
import Gallery from '../../components/Gallery.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import { getPublishedEntries, entrySlug } from '../../lib/portal';

export async function getStaticPaths() {
  const entries = await getPublishedEntries();

  return entries
    .filter((e) => e.id !== e.data.client)   // index entries are handled by [client]/index.astro
    .map((entry) => ({
      params: { client: entry.data.client, slug: entrySlug(entry) },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const assetLinks = entry.data.asset_links ?? [];
const gallery = entry.data.gallery ?? [];
const videos = entry.data.videos ?? [];
---
<PortalLayout
  title={entry.data.title}
  client={entry.data.client}
  status={entry.data.status}
  date={entry.data.date}
  type={entry.data.type}
>
  {assetLinks.length > 0 && (
    <AssetLink links={assetLinks} />
  )}
  {videos.length > 0 && (
    <VideoPlayer videos={videos} />
  )}
  <Content />
  {gallery.length > 0 && (
    <Gallery images={gallery} title={entry.data.title} />
  )}
</PortalLayout>
